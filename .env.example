# Gemini API Key (Required for AI planning, chat assistant, and tagging features)
# Get a key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Geoapify API Key (Required for primary live vendor search)
# Create a free account at: https://www.geoapify.com/
GEOAPIFY_API_KEY=

# Google Places API Key (Optional fallback for richer vendor data)
# Get key and enable Places API (New) in Google Cloud Console
GOOGLE_PLACES_API_KEY=

# Notion Integration (Optional cloud backup)
# Internal Integration Token from: https://www.notion.so/my-integrations
NOTION_TOKEN=

# Notion Database IDs (Auto-populated by setup-notion.js)
NOTION_DB_EVENTS=
NOTION_DB_VENDORS=
NOTION_DB_BOOKINGS=
NOTION_DB_FEEDBACK=
NOTION_DB_CHAT_LOGS=

# SMTP Email Configuration (Optional - for sending live invitations/reminders to attendees)
# For Gmail, use host: smtp.gmail.com, port: 587, and generate a Google App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
